# Environment
NODE_ENV=development

# Server Configuration
PORT=5000
HOST=localhost
API_PREFIX=/api

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/stockfilter_db"
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30000

# Redis Configuration
REDIS_URL="redis://:redis123@localhost:6379"
REDIS_SESSION_PREFIX="stockfilter:session:"
REDIS_CACHE_PREFIX="stockfilter:cache:"
REDIS_CACHE_TTL=3600

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Email Configuration (for notifications and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="StockFilter Pro <noreply@stockfilterpro.com>"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES="csv,xlsx,xls"

# External APIs
NSE_API_URL=https://www.nseindia.com/api
BSE_API_URL=https://api.bseindia.com
STOCK_DATA_API_KEY=your-stock-data-api-key

# Cron Jobs
ENABLE_CRON_JOBS=true
MARKET_DATA_UPDATE_CRON="0 */15 * * * *"
FINANCIAL_DATA_UPDATE_CRON="0 0 2 * * 0"

# Monitoring & Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
ENABLE_REQUEST_LOGGING=true

# Security
CORS_ORIGIN="http://localhost:3000"
SESSION_SECRET="your-session-secret-change-in-production"
BCRYPT_ROUNDS=12

# Features Flags
ENABLE_WEBSOCKETS=true
ENABLE_ELASTICSEARCH=false
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false

# Development
SWAGGER_ENABLED=true
DEBUG_MODE=true